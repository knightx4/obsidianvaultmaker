# Required: Claude for the vault-building agent (Messages API)
ANTHROPIC_API_KEY=

# Optional: override default model (see Anthropic docs for model IDs)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Recommended: Voyage AI embeddings (Anthropic has no public embedding API).
# Without VOYAGE_API_KEY, retrieval falls back to keyword matching only.
VOYAGE_API_KEY=

# Optional: Voyage embedding model (default voyage-3-large)
# VOYAGE_EMBEDDING_MODEL=voyage-3-large

# Optional: default vault path (can override in UI)
# VAULT_PATH=/path/to/your/vault

# Optional: server port (default 3840)
# PORT=3840
